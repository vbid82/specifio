# Specifio Backend Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://specifio_user:YOUR_PASSWORD@localhost:5432/specifio
DATABASE_URL_SYNC=postgresql://specifio_user:YOUR_PASSWORD@localhost:5432/specifio

# Auth
JWT_SECRET=GENERATE_WITH_python3_-c_"import_secrets;print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168
JWT_SECRET_ROTATED_AT=0
MAGIC_LINK_EXPIRY_MINUTES=30

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=hello@specifio.eu
EMAIL_FROM_NAME=Specifio
MAGIC_LINK_BASE_URL=https://specifio.eu/auth/verify

# HubSpot
HUBSPOT_ACCESS_TOKEN=pat-xxxxxxxxxxxx

# App
APP_ENV=production
APP_URL=https://specifio.eu
API_URL=https://api.specifio.eu
CORS_ORIGINS=https://specifio.eu,http://localhost:5173

# Rate limits
REGISTRATION_RATE_LIMIT_PER_IP=5
MAGIC_LINK_RATE_LIMIT_PER_EMAIL=3
